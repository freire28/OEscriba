@page "/pedidos"
@inject OescribaDbContext Db
@inject IJSRuntime JS

@using System.Globalization
@using System.IO
@using ClosedXML.Excel
@using Microsoft.EntityFrameworkCore
@using Microsoft.JSInterop
@using MCOEWeb.Data
@using MCOEWeb.Data.Entities

<PageTitle>Pedidos</PageTitle>

<h3>Pedidos</h3>

<div class="row g-2 align-items-end mb-3">
    <div class="col-md-3 col-lg-2">
        <label class="form-label small mb-0">Data pedido (de)</label>
        <input type="date" class="form-control form-control-sm"
               value="@ToYyyyMmDd(dataPedidoInicioEdicao)"
               @onchange="@(e => { dataPedidoInicioEdicao = ParseYyyyMmDd(e.Value); })" />
    </div>
    <div class="col-md-3 col-lg-2">
        <label class="form-label small mb-0">Data pedido (até)</label>
        <input type="date" class="form-control form-control-sm"
               value="@ToYyyyMmDd(dataPedidoFimEdicao)"
               @onchange="@(e => { dataPedidoFimEdicao = ParseYyyyMmDd(e.Value); })" />
    </div>
    <div class="col-md-2 col-lg-1">
        <label class="form-label small mb-0">UF</label>
        <input class="form-control form-control-sm text-uppercase" maxlength="2" placeholder="SP"
               @bind="filtroUfEdicao" />
    </div>
    <div class="col-md-4 col-lg-3">
        <label class="form-label small mb-0">Cliente</label>
        <input class="form-control form-control-sm" placeholder="Parte do nome"
               @bind="filtroClienteEdicao" />
    </div>
    <div class="col-md-auto">
        <button type="button" class="btn btn-primary btn-sm" @onclick="AplicarFiltrosAsync" disabled="@isLoading">
            @(isLoading ? "…" : "Filtrar")
        </button>
    </div>
    <div class="col-md-auto ms-md-auto">
        <span class="form-label small mb-0 d-block text-md-end">Visualização</span>
        <div class="d-flex flex-wrap justify-content-md-end gap-1 align-items-center">
            <div class="btn-group btn-group-sm" role="group" aria-label="Modo de visualização">
                <button type="button"
                        class="btn @(modoVisualizacao == VisualizacaoPedidos.Grid ? "btn-primary" : "btn-outline-primary")"
                        @onclick="@(() => modoVisualizacao = VisualizacaoPedidos.Grid)">Grid</button>
                <button type="button"
                        class="btn @(modoVisualizacao == VisualizacaoPedidos.Cards ? "btn-primary" : "btn-outline-primary")"
                        @onclick="@IrParaModoCards">Cards</button>
            </div>
            <button type="button" class="btn btn-success btn-sm" @onclick="ExportarExcelAsync"
                    disabled="@(isLoading || isExportando || !filtrosForamAplicados)"
                    title="Exporta para Excel todos os registros que atendem ao filtro atual (não só a página visível)">
                @(isExportando ? "…" : "Excel")
            </button>
        </div>
    </div>
</div>
@if (!string.IsNullOrEmpty(exportErro))
{
    <div class="alert alert-warning py-1 px-2 small mb-2" role="alert">@exportErro</div>
}

@if (isLoading)
{
    <div class="alert alert-info mt-3" role="alert">
        Carregando dados de <code>CONSOLIDADO_VENDAS</code>...
    </div>
}
else if (!string.IsNullOrWhiteSpace(erro))
{
    <div class="alert alert-danger mt-3" role="alert">@erro</div>
}
else if (!filtrosForamAplicados)
{
    <div class="alert alert-secondary mt-3" role="alert">
        Defina os filtros (opcional) e clique em <strong>Filtrar</strong> para carregar os pedidos.
    </div>
}
else
{
    @if (linhas.Count == 0)
    {
        <div class="alert alert-warning mt-3" role="alert">
            Nenhum registro encontrado em <code>CONSOLIDADO_VENDAS</code>@(TemAlgumFiltroAplicado() ? " com os filtros atuais" : "").
        </div>
    }
    else
    {
        @if (modoVisualizacao == VisualizacaoPedidos.Grid)
        {
            <div id="pedidos-grid-nav"
                 class="pedidos-tabela-wrap mt-3 pedidos-grid-nav-wrap"
                 tabindex="0"
                 @ref="gridNavRef"
                 @onkeydown="OnGridKeyDown">
                <p class="small text-muted mb-1">Clique numa linha para selecionar. Com o foco nesta área, use ↑ ↓, Home ou End para navegar.</p>
                <table id="pedidos-grid-resizable" class="table table-striped table-sm small mb-0 pedidos-tabela">
                    <colgroup>
                        <col class="col-ecom" />
                        <col class="col-cliente" />
                        <col class="col-uf" />
                        <col class="col-val" /><col class="col-val" /><col class="col-val" />
                        <col class="col-val" /><col class="col-val" /><col class="col-val" /><col class="col-val" />
                        <col class="col-val" /><col class="col-val" />
                    </colgroup>
                    <thead>
                        <tr>
                            <th scope="col">Nº e-com.</th>
                            <th scope="col">Cliente</th>
                            <th scope="col" class="text-center">UF</th>
                            <th scope="col" class="text-end text-nowrap">V. venda</th>
                            <th scope="col" class="text-end text-nowrap">Taxa MP</th>
                            <th scope="col" class="text-end text-nowrap">Frete</th>
                            <th scope="col" class="text-end text-nowrap">ICMS</th>
                            <th scope="col" class="text-end text-nowrap">PIS</th>
                            <th scope="col" class="text-end text-nowrap">COFINS</th>
                            <th scope="col" class="text-end text-nowrap">DIFAL</th>
                            <th scope="col" class="text-end text-nowrap">P. custo</th>
                            <th scope="col" class="text-end text-nowrap">MC</th>
                        </tr>
                    </thead>
                    <tbody>
                    @for (var i = 0; i < linhas.Count; i++)
                    {
                        var idx = i;
                        var linha = linhas[i];
                        <tr class="@ClasseLinhaGrid(linha.Mc, idx)"
                            aria-selected="@(indiceLinhaSelecionadaGrid == idx ? "true" : "false")"
                            @onclick="@(() => SelecionarLinhaGrid(idx))"
                            @ondblclick="@(() => AbrirDetalheModal(linha))">
                            <td class="text-nowrap">@FormatTexto(linha.NumeroEcommerce)</td>
                            <td class="text-truncate cliente-cell" title="@linha.Dados.Cliente">@linha.Dados.Cliente</td>
                            <td class="text-center text-nowrap">@linha.Dados.UfVenda</td>
                            <td class="text-end text-nowrap">@FormatCurrency(linha.Dados.ValorVenda)</td>
                            <td class="text-end text-nowrap">@FormatCurrency(linha.Dados.TaxaMarketplace)</td>
                            <td class="text-end text-nowrap">@FormatCurrency(linha.Dados.ValorFrete)</td>
                            <td class="text-end text-nowrap">@FormatCurrency(linha.Dados.Icms)</td>
                            <td class="text-end text-nowrap">@FormatCurrency(linha.Dados.Pis)</td>
                            <td class="text-end text-nowrap">@FormatCurrency(linha.Dados.Cofins)</td>
                            <td class="text-end text-nowrap">@FormatCurrency(linha.Dados.Difal)</td>
                            <td class="text-end text-nowrap">@FormatCurrency(linha.PrecoCustoTotal)</td>
                            <td class="text-end text-nowrap">@FormatMc(linha.Mc)</td>
                        </tr>
                    }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <div class="row row-cols-1 row-cols-lg-3 g-3 mt-3 pedidos-cards-grid">
                @foreach (var linha in linhas)
                {
                    <div class="col">
                        <div class="card h-100 shadow-sm @CardClass(linha.Mc)" @ondblclick="@(() => AbrirDetalheModal(linha))">
                            <div class="card-body py-2 px-3 small">
                                <div class="d-flex justify-content-between align-items-start gap-2 mb-2">
                                    <span class="fw-semibold">@linha.Dados.Cliente</span>
                                    <span class="badge bg-secondary flex-shrink-0">@linha.Dados.UfVenda</span>
                                </div>
                                <div class="d-flex justify-content-between align-items-baseline gap-2 mb-2 pb-2 pedidos-card-linha border-bottom border-secondary-subtle">
                                    <span class="text-muted">Nº e-com.</span>
                                    <span class="fw-bold text-end text-break">@FormatTexto(linha.NumeroEcommerce)</span>
                                </div>
                                <div class="vstack gap-0 pedidos-card-valores">
                                    <div class="d-flex justify-content-between align-items-baseline gap-2 py-1 pedidos-card-linha">
                                        <span class="text-muted">V. venda</span>
                                        <span class="fw-bold text-nowrap text-end">@FormatCurrency(linha.Dados.ValorVenda)</span>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-baseline gap-2 py-1 pedidos-card-linha">
                                        <span class="text-muted">Taxa MP</span>
                                        <span class="fw-bold text-nowrap text-end">@FormatCurrency(linha.Dados.TaxaMarketplace)</span>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-baseline gap-2 py-1 pedidos-card-linha">
                                        <span class="text-muted">Frete</span>
                                        <span class="fw-bold text-nowrap text-end">@FormatCurrency(linha.Dados.ValorFrete)</span>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-baseline gap-2 py-1 pedidos-card-linha">
                                        <span class="text-muted">ICMS</span>
                                        <span class="fw-bold text-nowrap text-end">@FormatCurrency(linha.Dados.Icms)</span>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-baseline gap-2 py-1 pedidos-card-linha">
                                        <span class="text-muted">PIS</span>
                                        <span class="fw-bold text-nowrap text-end">@FormatCurrency(linha.Dados.Pis)</span>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-baseline gap-2 py-1 pedidos-card-linha">
                                        <span class="text-muted">COFINS</span>
                                        <span class="fw-bold text-nowrap text-end">@FormatCurrency(linha.Dados.Cofins)</span>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-baseline gap-2 py-1 pedidos-card-linha">
                                        <span class="text-muted">DIFAL</span>
                                        <span class="fw-bold text-nowrap text-end">@FormatCurrency(linha.Dados.Difal)</span>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-baseline gap-2 py-1 pedidos-card-linha">
                                        <span class="text-muted">P. custo</span>
                                        <span class="fw-bold text-nowrap text-end">@FormatCurrency(linha.PrecoCustoTotal)</span>
                                    </div>
                                    <div class="d-flex justify-content-between align-items-baseline gap-2 py-1 pedidos-card-linha">
                                        <span class="text-muted">MC</span>
                                        <span class="fw-bold text-nowrap text-end">@FormatMc(linha.Mc)</span>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                }
            </div>
        }
    }
    <div class="mt-2 small">
        <p class="text-center text-muted mb-2 mb-md-3">
            @if (totalRegistros == 0)
            {
                <text>Nenhum registro.</text>
            }
            else
            {
                <text>Mostrando @PrimeiroItemPagina–@UltimoItemPagina de @totalRegistros registro(s).</text>
            }
        </p>
        <nav class="d-flex flex-column align-items-center gap-2" aria-label="Paginação">
            <ul class="pagination pagination-sm mb-0 flex-wrap justify-content-center">
                <li class="page-item @(paginaAtual <= 1 || isLoading || totalRegistros == 0 ? "disabled" : null)">
                    <button type="button" class="page-link py-1" title="Primeira página" @onclick="IrParaPrimeiraPaginaAsync" disabled="@(paginaAtual <= 1 || isLoading || totalRegistros == 0)">«</button>
                </li>
                <li class="page-item @(paginaAtual <= 1 || isLoading || totalRegistros == 0 ? "disabled" : null)">
                    <button type="button" class="page-link py-1" title="Página anterior" @onclick="PaginaAnteriorAsync" disabled="@(paginaAtual <= 1 || isLoading || totalRegistros == 0)">‹</button>
                </li>
                @foreach (var p in PaginasParaExibir())
                {
                    @if (p == paginaAtual)
                    {
                        <li class="page-item active" aria-current="page"><span class="page-link py-1 px-2">@p</span></li>
                    }
                    else
                    {
                        <li class="page-item">
                            <button type="button" class="page-link py-1 px-2" @onclick="@(() => IrParaPaginaAsync(p))" disabled="@(isLoading || totalRegistros == 0)">@p</button>
                        </li>
                    }
                }
                <li class="page-item @(paginaAtual >= TotalPaginas || isLoading || totalRegistros == 0 ? "disabled" : null)">
                    <button type="button" class="page-link py-1" title="Próxima página" @onclick="PaginaProximaAsync" disabled="@(paginaAtual >= TotalPaginas || isLoading || totalRegistros == 0)">›</button>
                </li>
                <li class="page-item @(paginaAtual >= TotalPaginas || isLoading || totalRegistros == 0 ? "disabled" : null)">
                    <button type="button" class="page-link py-1" title="Última página" @onclick="IrParaUltimaPaginaAsync" disabled="@(paginaAtual >= TotalPaginas || isLoading || totalRegistros == 0)">»</button>
                </li>
            </ul>
            <div class="d-flex flex-wrap align-items-center justify-content-center gap-2">
                <span class="text-muted">Página @paginaAtual de @TotalPaginas</span>
                <span class="text-muted">·</span>
                <label class="mb-0 small text-muted">Ir para</label>
                <input type="number" class="form-control form-control-sm d-inline-block"
                       style="width: 4.5rem; min-width: 4rem;"
                       min="1" max="@TotalPaginas"
                       @bind="paginaIrPara"
                       disabled="@(isLoading || totalRegistros == 0)" />
                <button type="button" class="btn btn-outline-secondary btn-sm" @onclick="IrParaPaginaInformadaAsync" disabled="@(isLoading || totalRegistros == 0)">Ir</button>
            </div>
        </nav>
    </div>
    <style>
        .pedidos-grid-nav-wrap { overflow-x: auto; }
        .pedidos-grid-nav-wrap:focus {
            outline: 2px solid var(--bs-primary);
            outline-offset: 2px;
        }
        .pedidos-tabela tbody tr.pedidos-linha-selecionada {
            box-shadow: inset 0 0 0 2px var(--bs-primary);
        }
        .pedidos-tabela tbody tr td {
            cursor: pointer;
        }
        .pedidos-tabela {
            table-layout: fixed;
            width: 100%;
            font-size: 0.78rem;
        }
        .pedidos-tabela thead th,
        .pedidos-tabela tbody td {
            padding: 0.2rem 0.3rem;
            vertical-align: middle;
        }
        /* Nº e-commerce mais largo; colunas monetárias mais estreitas (24+28+3+8×5.625 = 100%) */
        .pedidos-tabela .col-ecom { width: 24%; min-width: 7.5rem; }
        .pedidos-tabela .col-cliente { width: 28%; min-width: 6rem; }
        .pedidos-tabela .col-uf { width: 3%; min-width: 2rem; }
        .pedidos-tabela .col-val { width: 5.625%; min-width: 3.1rem; }
        .pedidos-tabela .cliente-cell {
            max-width: 0;
        }
        .pedidos-tabela thead th .pedidos-col-resizer {
            position: absolute;
            right: 0;
            top: 0;
            bottom: 0;
            width: 8px;
            cursor: col-resize;
            z-index: 2;
            margin-right: -4px;
        }
        .pedidos-tabela thead th .pedidos-col-resizer:hover {
            background: rgba(13, 110, 253, 0.2);
        }
        .pedidos-cards-grid .card.border-danger {
            background-color: rgba(var(--bs-danger-rgb), 0.08);
        }
        .pedidos-card-linha {
            min-height: 1.35rem;
        }
        .pedidos-card-valores .pedidos-card-linha + .pedidos-card-linha {
            border-top: 1px solid var(--bs-border-color-translucent);
        }
        .pedidos-cards-grid .card {
            cursor: pointer;
        }
        .pedidos-modal-overlay {
            position: fixed;
            inset: 0;
            z-index: 1055;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 1rem;
        }
        .pedidos-modal-backdrop {
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, 0.45);
            z-index: 0;
        }
        .pedidos-modal-dialog {
            position: relative;
            z-index: 1;
            max-width: min(96vw, 58rem);
            width: 100%;
            max-height: min(90vh, 900px);
            overflow: auto;
        }
        .pedidos-detalhe-form {
            font-size: 1.1rem;
        }
        .pedidos-detalhe-form .pedidos-detalhe-campo {
            margin-bottom: 0.35rem;
        }
        .pedidos-detalhe-form .pedidos-detalhe-campo:last-child {
            margin-bottom: 0;
        }
        .pedidos-detalhe-form .pedidos-detalhe-label {
            font-size: 0.95rem;
            color: var(--bs-secondary);
            margin-bottom: 0;
            line-height: 1.15;
        }
        .pedidos-detalhe-form .pedidos-detalhe-valor {
            font-size: 1.25rem;
            font-weight: 600;
            line-height: 1.2;
        }
        .pedidos-detalhe-mc-bloco {
            position: sticky;
            top: 0;
            padding: 0.75rem 0.5rem;
            border-radius: var(--bs-border-radius);
            background: rgba(var(--bs-primary-rgb), 0.08);
            border: 1px solid rgba(var(--bs-primary-rgb), 0.25);
            min-height: 6rem;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            text-align: center;
        }
        .pedidos-detalhe-mc-bloco .pedidos-detalhe-label {
            font-size: 1rem;
            margin-bottom: 0.25rem;
        }
        .pedidos-detalhe-mc-valor {
            font-size: 2.1rem;
            font-weight: 700;
            line-height: 1.1;
        }
        @@media (min-width: 992px) {
            .pedidos-detalhe-mc-bloco {
                min-height: 100%;
            }
        }
    </style>
    @if (linhaDetalheModal is not null)
    {
        var d = linhaDetalheModal;
        <div class="pedidos-modal-overlay" role="dialog" aria-modal="true" aria-labelledby="pedidos-modal-titulo">
            <div class="pedidos-modal-backdrop" @onclick="FecharModalDetalhe"></div>
            <div class="pedidos-modal-dialog card shadow-lg" @onclick:stopPropagation="true">
                <div class="card-header d-flex justify-content-between align-items-center py-3">
                    <h4 class="mb-0" id="pedidos-modal-titulo">Detalhe do registro</h4>
                    <button type="button" class="btn-close" @onclick="FecharModalDetalhe" aria-label="Fechar"></button>
                </div>
                <div class="card-body pedidos-detalhe-form px-3 py-3">
                    <div class="row g-2 g-lg-3 align-items-lg-stretch">
                        <div class="col-lg-4 col-12">
                            <div class="pedidos-detalhe-campo">
                                <div class="pedidos-detalhe-label">Id consolidação</div>
                                <div class="pedidos-detalhe-valor">@d.Dados.IdConsolidacao</div>
                            </div>
                            <div class="pedidos-detalhe-campo">
                                <div class="pedidos-detalhe-label">Id nota</div>
                                <div class="pedidos-detalhe-valor">@d.Dados.IdNota</div>
                            </div>
                            <div class="pedidos-detalhe-campo">
                                <div class="pedidos-detalhe-label">Nº e-commerce</div>
                                <div class="pedidos-detalhe-valor">@FormatTexto(d.NumeroEcommerce)</div>
                            </div>
                            <div class="pedidos-detalhe-campo">
                                <div class="pedidos-detalhe-label">Cliente</div>
                                <div class="pedidos-detalhe-valor">@d.Dados.Cliente</div>
                            </div>
                            <div class="pedidos-detalhe-campo">
                                <div class="pedidos-detalhe-label">UF</div>
                                <div class="pedidos-detalhe-valor">@d.Dados.UfVenda</div>
                            </div>
                        </div>
                        <div class="col-lg-4 col-12">
                            <div class="pedidos-detalhe-campo">
                                <div class="pedidos-detalhe-label">Valor venda</div>
                                <div class="pedidos-detalhe-valor">@FormatCurrency(d.Dados.ValorVenda)</div>
                            </div>
                            <div class="pedidos-detalhe-campo">
                                <div class="pedidos-detalhe-label">Taxa marketplace</div>
                                <div class="pedidos-detalhe-valor">@FormatCurrency(d.Dados.TaxaMarketplace)</div>
                            </div>
                            <div class="pedidos-detalhe-campo">
                                <div class="pedidos-detalhe-label">Frete</div>
                                <div class="pedidos-detalhe-valor">@FormatCurrency(d.Dados.ValorFrete)</div>
                            </div>
                            <div class="pedidos-detalhe-campo">
                                <div class="pedidos-detalhe-label">ICMS</div>
                                <div class="pedidos-detalhe-valor">@FormatCurrency(d.Dados.Icms)</div>
                            </div>
                            <div class="pedidos-detalhe-campo">
                                <div class="pedidos-detalhe-label">PIS</div>
                                <div class="pedidos-detalhe-valor">@FormatCurrency(d.Dados.Pis)</div>
                            </div>
                            <div class="pedidos-detalhe-campo">
                                <div class="pedidos-detalhe-label">COFINS</div>
                                <div class="pedidos-detalhe-valor">@FormatCurrency(d.Dados.Cofins)</div>
                            </div>
                            <div class="pedidos-detalhe-campo">
                                <div class="pedidos-detalhe-label">DIFAL</div>
                                <div class="pedidos-detalhe-valor">@FormatCurrency(d.Dados.Difal)</div>
                            </div>
                            <div class="pedidos-detalhe-campo">
                                <div class="pedidos-detalhe-label">Preço de custo (itens)</div>
                                <div class="pedidos-detalhe-valor">@FormatCurrency(d.PrecoCustoTotal)</div>
                            </div>
                        </div>
                        <div class="col-lg-4 col-12 d-flex">
                            <div class="pedidos-detalhe-mc-bloco flex-grow-1 w-100">
                                <div class="pedidos-detalhe-label">Margem de contribuição</div>
                                <div class="pedidos-detalhe-mc-valor @(d.Mc is < 0 ? "text-danger" : null)">@FormatMc(d.Mc)</div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="card-footer bg-light py-3 text-end">
                    <button type="button" class="btn btn-primary btn-lg" @onclick="FecharModalDetalhe">Fechar</button>
                </div>
            </div>
        </div>
    }
}

@code {
    private enum VisualizacaoPedidos
    {
        Grid,
        Cards
    }

    private const int TamanhoPagina = 25;

    private VisualizacaoPedidos modoVisualizacao = VisualizacaoPedidos.Grid;

    private bool isLoading;
    private string? erro;
    private string? exportErro;
    private bool isExportando;
    private List<LinhaConsolidadoMc> linhas = new();

    private bool filtrosForamAplicados;
    private int paginaAtual = 1;
    private int paginaIrPara = 1;
    private int totalRegistros;

    private int? indiceLinhaSelecionadaGrid;
    private LinhaConsolidadoMc? linhaDetalheModal;
    private ElementReference gridNavRef;

    private DateTime? dataPedidoInicioEdicao = DateTime.Today;
    private DateTime? dataPedidoFimEdicao = DateTime.Today;
    private string filtroUfEdicao = string.Empty;
    private string filtroClienteEdicao = string.Empty;

    private DateTime? dataPedidoInicio;
    private DateTime? dataPedidoFim;
    private string filtroUf = string.Empty;
    private string filtroCliente = string.Empty;

    private int TotalPaginas => totalRegistros <= 0 ? 1 : (totalRegistros + TamanhoPagina - 1) / TamanhoPagina;

    private int PrimeiroItemPagina => totalRegistros == 0 ? 0 : (paginaAtual - 1) * TamanhoPagina + 1;

    private int UltimoItemPagina => totalRegistros == 0 ? 0 : Math.Min(paginaAtual * TamanhoPagina, totalRegistros);

    private const string PedidosGridTableId = "pedidos-grid-resizable";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (modoVisualizacao != VisualizacaoPedidos.Grid || linhas.Count == 0 || isLoading)
            return;

        try
        {
            await Task.Delay(1);
            await JS.InvokeVoidAsync("pedidosGridResize.init", PedidosGridTableId);
            await JS.InvokeVoidAsync("pedidosGridNav.setupKeyboard", "pedidos-grid-nav");
        }
        catch (JSException)
        {
        }
        catch (InvalidOperationException)
        {
        }
    }

    private void IrParaModoCards()
    {
        modoVisualizacao = VisualizacaoPedidos.Cards;
        indiceLinhaSelecionadaGrid = null;
        linhaDetalheModal = null;
    }

    private void AbrirDetalheModal(LinhaConsolidadoMc linha)
    {
        linhaDetalheModal = linha;
    }

    private void FecharModalDetalhe()
    {
        linhaDetalheModal = null;
    }

    private async Task SelecionarLinhaGrid(int indice)
    {
        if (indice < 0 || indice >= linhas.Count)
            return;
        indiceLinhaSelecionadaGrid = indice;
        await gridNavRef.FocusAsync();
    }

    private void OnGridKeyDown(KeyboardEventArgs e)
    {
        if (linhas.Count == 0)
            return;

        var max = linhas.Count - 1;
        switch (e.Key)
        {
            case "ArrowDown":
                indiceLinhaSelecionadaGrid = indiceLinhaSelecionadaGrid is int d
                    ? Math.Min(max, d + 1)
                    : 0;
                break;
            case "ArrowUp":
                indiceLinhaSelecionadaGrid = indiceLinhaSelecionadaGrid is int u
                    ? Math.Max(0, u - 1)
                    : max;
                break;
            case "Home":
                indiceLinhaSelecionadaGrid = 0;
                break;
            case "End":
                indiceLinhaSelecionadaGrid = max;
                break;
            default:
                return;
        }
    }

    private string ClasseLinhaGrid(decimal? mc, int indice)
    {
        var sel = indiceLinhaSelecionadaGrid == indice ? "pedidos-linha-selecionada" : null;
        var neg = RowClass(mc);
        if (sel != null && neg != null)
            return $"{sel} {neg}";
        return sel ?? neg ?? string.Empty;
    }

    private async Task AplicarFiltrosAsync()
    {
        dataPedidoInicio = dataPedidoInicioEdicao;
        dataPedidoFim = dataPedidoFimEdicao;
        filtroUf = filtroUfEdicao ?? string.Empty;
        filtroCliente = filtroClienteEdicao ?? string.Empty;
        filtrosForamAplicados = true;
        exportErro = null;
        paginaAtual = 1;
        await CarregarDadosAsync();
    }

    private async Task ExportarExcelAsync()
    {
        exportErro = null;
        if (!filtrosForamAplicados)
            return;

        isExportando = true;
        try
        {
            var consolidados = await QueryConsolidadosFiltradosTodosAsync();
            var linhasExport = await MontarLinhasComMargemAsync(consolidados);

            using var stream = new MemoryStream();
            using (var wb = new XLWorkbook())
            {
                var ws = wb.Worksheets.Add("Pedidos");
                ws.Cell(1, 1).Value = "Nº e-commerce";
                ws.Cell(1, 2).Value = "Cliente";
                ws.Cell(1, 3).Value = "UF";
                ws.Cell(1, 4).Value = "Valor venda";
                ws.Cell(1, 5).Value = "Taxa marketplace";
                ws.Cell(1, 6).Value = "Frete";
                ws.Cell(1, 7).Value = "ICMS";
                ws.Cell(1, 8).Value = "PIS";
                ws.Cell(1, 9).Value = "COFINS";
                ws.Cell(1, 10).Value = "DIFAL";
                ws.Cell(1, 11).Value = "Preço custo (itens)";
                ws.Cell(1, 12).Value = "MC";
                ws.Row(1).Style.Font.Bold = true;

                var fmt = "#,##0.00";
                var r = 2;
                foreach (var linha in linhasExport)
                {
                    ws.Cell(r, 1).Value = linha.NumeroEcommerce ?? string.Empty;
                    ws.Cell(r, 2).Value = linha.Dados.Cliente;
                    ws.Cell(r, 3).Value = linha.Dados.UfVenda;
                    ws.Cell(r, 4).Value = linha.Dados.ValorVenda;
                    ws.Cell(r, 4).Style.NumberFormat.Format = fmt;
                    ws.Cell(r, 5).Value = linha.Dados.TaxaMarketplace;
                    ws.Cell(r, 5).Style.NumberFormat.Format = fmt;
                    ws.Cell(r, 6).Value = linha.Dados.ValorFrete;
                    ws.Cell(r, 6).Style.NumberFormat.Format = fmt;
                    ws.Cell(r, 7).Value = linha.Dados.Icms;
                    ws.Cell(r, 7).Style.NumberFormat.Format = fmt;
                    ws.Cell(r, 8).Value = linha.Dados.Pis;
                    ws.Cell(r, 8).Style.NumberFormat.Format = fmt;
                    ws.Cell(r, 9).Value = linha.Dados.Cofins;
                    ws.Cell(r, 9).Style.NumberFormat.Format = fmt;
                    ws.Cell(r, 10).Value = linha.Dados.Difal;
                    ws.Cell(r, 10).Style.NumberFormat.Format = fmt;
                    ws.Cell(r, 11).Value = linha.PrecoCustoTotal;
                    ws.Cell(r, 11).Style.NumberFormat.Format = fmt;
                    ws.Cell(r, 12).Value = linha.Mc;
                    ws.Cell(r, 12).Style.NumberFormat.Format = fmt;
                    r++;
                }

                ws.Columns().AdjustToContents();
                wb.SaveAs(stream);
            }

            stream.Position = 0;
            var nome = $"Pedidos_{DateTime.Now:yyyyMMdd_HHmmss}.xlsx";
            var base64 = Convert.ToBase64String(stream.ToArray());
            await JS.InvokeVoidAsync("pedidosExport.downloadXlsx", nome, base64);
        }
        catch (Exception ex)
        {
            exportErro = $"Não foi possível exportar para Excel: {ex.Message}";
        }
        finally
        {
            isExportando = false;
        }
    }

    private async Task PaginaAnteriorAsync()
    {
        if (paginaAtual <= 1)
            return;
        paginaAtual--;
        await CarregarDadosAsync();
    }

    private async Task PaginaProximaAsync()
    {
        if (paginaAtual >= TotalPaginas)
            return;
        paginaAtual++;
        await CarregarDadosAsync();
    }

    private async Task IrParaPrimeiraPaginaAsync()
    {
        if (totalRegistros == 0 || paginaAtual <= 1)
            return;
        paginaAtual = 1;
        await CarregarDadosAsync();
    }

    private async Task IrParaUltimaPaginaAsync()
    {
        if (totalRegistros == 0 || paginaAtual >= TotalPaginas)
            return;
        paginaAtual = TotalPaginas;
        await CarregarDadosAsync();
    }

    private async Task IrParaPaginaAsync(int p)
    {
        if (totalRegistros == 0 || p < 1 || p > TotalPaginas || p == paginaAtual)
            return;
        paginaAtual = p;
        await CarregarDadosAsync();
    }

    private async Task IrParaPaginaInformadaAsync()
    {
        if (totalRegistros == 0)
            return;
        var p = paginaIrPara;
        if (p < 1)
            p = 1;
        else if (p > TotalPaginas)
            p = TotalPaginas;
        if (p == paginaAtual)
            return;
        paginaAtual = p;
        await CarregarDadosAsync();
    }

    private IEnumerable<int> PaginasParaExibir()
    {
        var total = TotalPaginas;
        if (total <= 0)
            yield break;

        const int maxBotoes = 9;
        if (total <= maxBotoes)
        {
            for (var i = 1; i <= total; i++)
                yield return i;
            yield break;
        }

        var end = Math.Min(total, paginaAtual + maxBotoes / 2);
        var start = Math.Max(1, end - maxBotoes + 1);
        end = Math.Min(total, start + maxBotoes - 1);
        start = Math.Max(1, end - maxBotoes + 1);

        for (var i = start; i <= end; i++)
            yield return i;
    }

    private async Task CarregarDadosAsync()
    {
        if (!filtrosForamAplicados)
            return;

        isLoading = true;
        erro = null;
        try
        {
            var consolidados = await QueryConsolidadosFiltradosPaginadoAsync();
            linhas = await MontarLinhasComMargemAsync(consolidados);
        }
        catch (Exception ex)
        {
            erro = $"Erro ao carregar dados de CONSOLIDADO_VENDAS: {ex.Message}";
            linhas.Clear();
            totalRegistros = 0;
        }
        finally
        {
            isLoading = false;
            paginaIrPara = paginaAtual;
            indiceLinhaSelecionadaGrid = null;
            linhaDetalheModal = null;
        }
    }

    private IQueryable<ConsolidadoVendas> BuildConsolidadosQueryAplicado()
    {
        IQueryable<ConsolidadoVendas> q;

        if (TemFiltroDataPedido())
        {
            var (inicioDia, fimExclusivo) = ObterIntervaloDataPedido();
            q =
                from c in Db.ConsolidadoVendas.AsNoTracking()
                join nf in Db.NotasFiscais.AsNoTracking() on c.IdNota equals nf.IdNotaFiscal
                join ped in Db.Pedidos.AsNoTracking() on nf.IdPedido!.Trim() equals ped.IdTiny
                where ped.DataPedido >= inicioDia && ped.DataPedido < fimExclusivo
                select c;
        }
        else
        {
            q = Db.ConsolidadoVendas.AsNoTracking();
        }

        if (!string.IsNullOrWhiteSpace(filtroUf))
        {
            var uf = NormalizarUf(filtroUf);
            if (uf.Length > 0)
                q = q.Where(c => c.UfVenda == uf);
        }

        if (!string.IsNullOrWhiteSpace(filtroCliente))
        {
            var termo = filtroCliente.Trim();
            q = q.Where(c => c.Cliente.Contains(termo));
        }

        return q;
    }

    private async Task<List<ConsolidadoVendas>> QueryConsolidadosFiltradosPaginadoAsync()
    {
        var q = BuildConsolidadosQueryAplicado();

        totalRegistros = await q
            .Select(c => c.IdConsolidacao)
            .Distinct()
            .CountAsync();

        if (totalRegistros == 0)
            return new List<ConsolidadoVendas>();

        var totalPaginas = (totalRegistros + TamanhoPagina - 1) / TamanhoPagina;
        if (paginaAtual > totalPaginas)
            paginaAtual = totalPaginas;
        if (paginaAtual < 1)
            paginaAtual = 1;

        var skip = (paginaAtual - 1) * TamanhoPagina;

        var ids = await q
            .Select(c => c.IdConsolidacao)
            .Distinct()
            .OrderByDescending(id => id)
            .Skip(skip)
            .Take(TamanhoPagina)
            .ToListAsync();

        if (ids.Count == 0)
            return new List<ConsolidadoVendas>();

        return await Db.ConsolidadoVendas
            .AsNoTracking()
            .Where(c => ids.Contains(c.IdConsolidacao))
            .OrderByDescending(c => c.IdConsolidacao)
            .ToListAsync();
    }

    /// <summary>Todos os registros que atendem ao filtro atual (sem paginação), para exportação Excel.</summary>
    private async Task<List<ConsolidadoVendas>> QueryConsolidadosFiltradosTodosAsync()
    {
        var q = BuildConsolidadosQueryAplicado();
        var ids = await q
            .Select(c => c.IdConsolidacao)
            .Distinct()
            .OrderByDescending(id => id)
            .ToListAsync();

        if (ids.Count == 0)
            return new List<ConsolidadoVendas>();

        return await Db.ConsolidadoVendas
            .AsNoTracking()
            .Where(c => ids.Contains(c.IdConsolidacao))
            .OrderByDescending(c => c.IdConsolidacao)
            .ToListAsync();
    }

    private bool TemFiltroDataPedido() => dataPedidoInicio.HasValue || dataPedidoFim.HasValue;

    private bool TemAlgumFiltroAplicado() =>
        TemFiltroDataPedido()
        || !string.IsNullOrWhiteSpace(filtroUf)
        || !string.IsNullOrWhiteSpace(filtroCliente);

    private (DateTime InicioDia, DateTime FimExclusivo) ObterIntervaloDataPedido()
    {
        var i = dataPedidoInicio?.Date;
        var f = dataPedidoFim?.Date;
        DateTime inicio;
        DateTime fimInclusivo;
        if (i.HasValue && f.HasValue)
        {
            inicio = i.Value;
            fimInclusivo = f.Value;
            if (inicio > fimInclusivo)
                (inicio, fimInclusivo) = (fimInclusivo, inicio);
        }
        else if (i.HasValue)
        {
            inicio = i.Value;
            fimInclusivo = i.Value;
        }
        else
        {
            fimInclusivo = f!.Value;
            inicio = fimInclusivo;
        }

        return (inicio, fimInclusivo.AddDays(1));
    }

    private static string NormalizarUf(string uf)
    {
        var t = uf.Trim().ToUpperInvariant();
        return t.Length <= 2 ? t : t[..2];
    }

    private static string? ToYyyyMmDd(DateTime? d) =>
        d.HasValue ? d.Value.ToString("yyyy-MM-dd", CultureInfo.InvariantCulture) : null;

    private static DateTime? ParseYyyyMmDd(object? v)
    {
        var s = v?.ToString();
        if (string.IsNullOrWhiteSpace(s))
            return null;
        return DateTime.ParseExact(s.Trim(), "yyyy-MM-dd", CultureInfo.InvariantCulture);
    }

    private static string? RowClass(decimal? mc) =>
        mc is < 0m ? "table-danger" : null;

    private static string CardClass(decimal? mc) =>
        mc is < 0m ? "border-danger" : "border-light";

    /// <summary>
    /// MC = VALOR_VENDA - (TAXA_MARKETPLACE + VALOR_FRETE + ICMS + PIS + COFINS + DIFAL + soma custos),
    /// com custo por item = PRECO_CUSTO (PRODUTOS) × Quantidade (ItensPedido), via NOTAS_FISCAIS → PEDIDOS → ItensPedido → PRODUTOS.
    /// </summary>
    private async Task<List<LinhaConsolidadoMc>> MontarLinhasComMargemAsync(List<ConsolidadoVendas> consolidados)
    {
        if (consolidados.Count == 0)
            return new List<LinhaConsolidadoMc>();

        var idNotas = consolidados.Select(c => c.IdNota).Distinct().ToList();

        var notasList = await Db.NotasFiscais
            .AsNoTracking()
            .Where(n => idNotas.Contains(n.IdNotaFiscal))
            .ToListAsync();

        var notaPorIdNota = notasList
            .GroupBy(n => n.IdNotaFiscal)
            .ToDictionary(g => g.Key, g => g.First());

        var idTinysPedido = notaPorIdNota.Values
            .Select(n => (n.IdPedido ?? "").Trim())
            .Where(s => s.Length > 0)
            .Distinct()
            .ToList();

        var pedidosList = idTinysPedido.Count == 0
            ? new List<Pedido>()
            : await Db.Pedidos
                .AsNoTracking()
                .Where(p => idTinysPedido.Contains(p.IdTiny))
                .ToListAsync();

        var pedidoPorIdTiny = pedidosList
            .GroupBy(p => p.IdTiny)
            .ToDictionary(g => g.Key, g => g.First());

        var idsPedidoInterno = pedidosList.Select(p => (long)p.IdPedido).Distinct().ToList();

        var itensList = idsPedidoInterno.Count == 0
            ? new List<ItensPedido>()
            : await Db.ItensPedidos
                .AsNoTracking()
                .Where(i => i.IdPedido.HasValue && idsPedidoInterno.Contains(i.IdPedido.Value))
                .ToListAsync();

        var itensPorPedido = itensList
            .GroupBy(i => i.IdPedido!.Value)
            .ToDictionary(g => g.Key, g => g.ToList());

        var chavesProdutoTiny = itensList
            .Where(i => i.IdProduto.HasValue)
            .Select(i => IdProdutoParaChaveTiny(i.IdProduto!.Value))
            .Where(k => k.Length > 0)
            .Distinct()
            .ToList();

        var produtosList = chavesProdutoTiny.Count == 0
            ? new List<Produto>()
            : await Db.Produtos
                .AsNoTracking()
                .Where(p => chavesProdutoTiny.Contains(p.IdProdutoTiny))
                .ToListAsync();

        var custoPorIdProdutoTiny = produtosList.ToDictionary(p => p.IdProdutoTiny, p => p.PrecoCusto);

        var resultado = new List<LinhaConsolidadoMc>(consolidados.Count);

        foreach (var c in consolidados)
        {
            decimal? mc = null;
            decimal? precoCustoTotal = null;
            string? numeroEcommerce = null;

            if (notaPorIdNota.TryGetValue(c.IdNota, out var nf))
            {
                var idTiny = (nf.IdPedido ?? "").Trim();
                if (idTiny.Length > 0 && pedidoPorIdTiny.TryGetValue(idTiny, out var ped))
                {
                    numeroEcommerce = string.IsNullOrWhiteSpace(ped.NumeroEcommerce) ? null : ped.NumeroEcommerce.Trim();
                    var somaCusto = SomarCustoItensPedido((long)ped.IdPedido, itensPorPedido, custoPorIdProdutoTiny);
                    precoCustoTotal = somaCusto;
                    mc = CalcularMargemContribuicao(c, somaCusto);
                }
            }

            resultado.Add(new LinhaConsolidadoMc
            {
                Dados = c,
                Mc = mc,
                NumeroEcommerce = numeroEcommerce,
                PrecoCustoTotal = precoCustoTotal
            });
        }

        return resultado;
    }

    private static string IdProdutoParaChaveTiny(long idProdutoTiny) =>
        idProdutoTiny.ToString(CultureInfo.InvariantCulture);

    private static decimal SomarCustoItensPedido(
        long idPedidoInterno,
        IReadOnlyDictionary<long, List<ItensPedido>> itensPorPedido,
        IReadOnlyDictionary<string, decimal> custoPorIdProdutoTiny)
    {
        if (!itensPorPedido.TryGetValue(idPedidoInterno, out var itens))
            return 0m;

        decimal soma = 0;
        foreach (var it in itens)
        {
            if (!it.IdProduto.HasValue)
                continue;

            var chave = IdProdutoParaChaveTiny(it.IdProduto.Value);
            if (!custoPorIdProdutoTiny.TryGetValue(chave, out var precoCusto))
                continue;

            var q = it.Quantidade ?? 1m;
            soma += precoCusto * q;
        }

        return soma;
    }

    /// <summary>
    /// MC = VALOR_VENDA - (COALESCE(taxa,0) + frete + ICMS + PIS + COFINS + DIFAL + soma dos custos).
    /// </summary>
    private static decimal CalcularMargemContribuicao(ConsolidadoVendas a, decimal somaPrecoCustoProdutos)
    {
        var vv = a.ValorVenda ?? 0m;
        var taxa = a.TaxaMarketplace ?? 0m;
        var frete = a.ValorFrete ?? 0m;
        var icms = a.Icms ?? 0m;
        var pis = a.Pis ?? 0m;
        var cofins = a.Cofins ?? 0m;
        var difal = a.Difal ?? 0m;

        return vv - (taxa + frete + icms + pis + cofins + difal + somaPrecoCustoProdutos);
    }

    private static string FormatCurrency(decimal? valor) =>
        valor.HasValue ? valor.Value.ToString("C2", CultureInfo.GetCultureInfo("pt-BR")) : "-";

    private static string FormatMc(decimal? valor) =>
        valor.HasValue ? valor.Value.ToString("C2", CultureInfo.GetCultureInfo("pt-BR")) : "-";

    private static string FormatTexto(string? valor) =>
        string.IsNullOrWhiteSpace(valor) ? "-" : valor;

    private sealed class LinhaConsolidadoMc
    {
        public required ConsolidadoVendas Dados { get; init; }
        public decimal? Mc { get; init; }
        public string? NumeroEcommerce { get; init; }
        /// <summary>Soma de PRECO_CUSTO × quantidade dos itens do pedido (PRODUTOS + ItensPedido).</summary>
        public decimal? PrecoCustoTotal { get; init; }
    }
}
