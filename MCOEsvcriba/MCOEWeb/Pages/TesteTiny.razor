@page "/teste-tiny"
@inject MCOEWeb.Services.TinyApiClient TinyApi

<PageTitle>Teste API Tiny</PageTitle>

<h3>Teste API Tiny - notas.fiscais.pesquisa</h3>

<div class="mb-3">
    <label class="form-label">Token da API Tiny</label>
    <input class="form-control" @bind="token" />
</div>

<button class="btn btn-primary" @onclick="ChamarApi" disabled="@isLoading">
    @(isLoading ? "Chamando..." : "Chamar API")
</button>

@if (!string.IsNullOrWhiteSpace(resultado))
{
    <pre class="mt-3">@resultado</pre>
}

@code {
    private string token = string.Empty;
    private string? resultado;
    private bool isLoading;

    private async Task ChamarApi()
    {
        if (string.IsNullOrWhiteSpace(token))
        {
            resultado = "Informe o token da API Tiny.";
            return;
        }

        isLoading = true;
        resultado = null;

        try
        {
            // Exemplo de filtro opcional: situação, data, etc.
            var filtros = new Dictionary<string, string>
            {
                // ["situacao"] = "aprovado"
            };

            var resposta = await TinyApi.PesquisarNotasFiscaisAsync(token, filtros);
            resultado = resposta;
        }
        catch (Exception ex)
        {
            resultado = $"Erro ao chamar API: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }
}

