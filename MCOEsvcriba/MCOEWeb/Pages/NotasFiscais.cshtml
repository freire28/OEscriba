@page "/notas-fiscais"
@model NotasFiscaisModel
@{
    ViewData["Title"] = "Notas fiscais";
}

<h3>Notas fiscais — pesquisa</h3>

<form method="post" class="mb-3">
    <div class="mb-3">
        <label asp-for="Token" class="form-label">Token da API Tiny</label>
        <input asp-for="Token" class="form-control" />
    </div>
    <div class="mb-3">
        <label asp-for="Pagina" class="form-label">Página</label>
        <input asp-for="Pagina" type="number" class="form-control" min="1" />
    </div>
    <button type="submit" class="btn btn-primary">Carregar notas fiscais</button>
</form>

@if (!string.IsNullOrWhiteSpace(Model.Erro))
{
    <div class="alert alert-danger mt-3">@Model.Erro</div>
}

@if (Model.Notas.Count > 0)
{
    <table class="table table-striped table-sm mt-3">
        <thead>
            <tr>
                <th>Id</th>
                <th>Número</th>
                <th>Série</th>
                <th>Data emissão</th>
                <th>Cliente</th>
                <th class="text-end">Valor produtos</th>
                <th class="text-end">Valor frete</th>
                <th>Situação</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var n in Model.Notas)
        {
            <tr>
                <td>@n.Id</td>
                <td>@n.Numero</td>
                <td>@n.Serie</td>
                <td>@n.DataEmissao</td>
                <td>@n.NomeCliente</td>
                <td class="text-end">@NotasFiscaisModel.FormatCurrency(n.ValorProdutos)</td>
                <td class="text-end">@NotasFiscaisModel.FormatCurrency(n.ValorFrete)</td>
                <td>@n.DescricaoSituacao</td>
            </tr>
        }
        </tbody>
    </table>
}
