@page "/callback-mercadolivre"
@inject MercadoLivreApiClient MercadoLivre
@inject NavigationManager Nav

<PageTitle>Callback Mercado Livre</PageTitle>

<h3>Autorização Mercado Livre</h3>

@if (isLoading)
{
    <p>Processando autorização...</p>
}
else if (!string.IsNullOrWhiteSpace(erro))
{
    <div class="alert alert-danger">@erro</div>
    <p><a href="mercadolivre-demo">Voltar ao exemplo</a></p>
}
else if (!string.IsNullOrWhiteSpace(userJson))
{
    <div class="alert alert-success">Token obtido com sucesso.</div>
    @if (!string.IsNullOrWhiteSpace(resumoToken))
    {
        <p class="small text-muted">@resumoToken</p>
    }
    <h4 class="mt-3">Resposta de <code>GET /users/me</code></h4>
    <pre class="bg-light p-3 rounded border" style="max-height: 400px; overflow: auto;">@userJson</pre>
    <p class="mt-3"><a href="mercadolivre-demo" class="btn btn-outline-primary">Voltar ao exemplo</a></p>
}

@code {
    private bool isLoading = true;
    private string? erro;
    private string? userJson;
    private string? resumoToken;

    protected override async Task OnInitializedAsync()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query);

        if (query.TryGetValue("error", out var err))
        {
            var desc = query.TryGetValue("error_description", out var ed) ? ed.ToString() : "";
            erro = $"Autorização recusada: {err} {desc}";
            isLoading = false;
            return;
        }

        if (!query.TryGetValue("code", out var code) || string.IsNullOrWhiteSpace(code))
        {
            erro = "Nenhum código (code) na URL. Cadastre no Mercado Livre a Redirect URI exatamente igual à desta página (incluindo o caminho /callback-mercadolivre).";
            isLoading = false;
            return;
        }

        try
        {
            var tokenResponse = await MercadoLivre.GetTokenAsync(code.ToString());
            resumoToken = $"Expira em {tokenResponse.ExpiresIn} segundos. Guarde o refresh_token em banco/sessão para renovar. User ID: {tokenResponse.UserId}";

            userJson = await MercadoLivre.GetAsync("users/me");
        }
        catch (Exception ex)
        {
            erro = ex.Message;
        }
        finally
        {
            isLoading = false;
        }
    }
}
