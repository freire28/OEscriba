@page "/produtos"
@inject MCOEWeb.Services.TinyApiClient TinyApi

<PageTitle>Produtos</PageTitle>

<h3>Produtos - Preços e Tributos</h3>

<div class="mb-3">
    <label class="form-label">Token da API Tiny</label>
    <input class="form-control" @bind="token" />
</div>

<div class="mb-3">
    <label class="form-label">Pesquisa (nome ou código)</label>
    <input class="form-control" @bind="pesquisa" />
</div>

<button class="btn btn-primary" @onclick="CarregarProdutos" disabled="@isLoading">
    @(isLoading ? "Carregando..." : "Carregar produtos")
</button>

@if (!string.IsNullOrWhiteSpace(erro))
{
    <div class="alert alert-danger mt-3">@erro</div>
}

@if (produtos is not null && produtos.Count > 0)
{
    <table class="table table-striped table-sm mt-3">
        <thead>
            <tr>
                <th>Produto</th>
                <th class="text-end">Preço Custo</th>
                <th class="text-end">Preço Venda</th>
                <th class="text-end">Frete</th>
                <th class="text-end">ICMS</th>
                <th class="text-end">PIS</th>
                <th class="text-end">COFINS</th>
                <th class="text-end">DIFAL</th>
            </tr>
        </thead>
        <tbody>
        @foreach (var p in produtos)
        {
            <tr>
                <td>@p.Nome</td>
                <td class="text-end">@FormatCurrency(p.PrecoCusto)</td>
                <td class="text-end">@FormatCurrency(p.PrecoVenda)</td>
                <td class="text-end">@FormatCurrency(p.ValorFrete)</td>
                <td class="text-end">@FormatCurrency(p.Icms)</td>
                <td class="text-end">@FormatCurrency(p.Pis)</td>
                <td class="text-end">@FormatCurrency(p.Cofins)</td>
                <td class="text-end">@FormatCurrency(p.Difal)</td>
            </tr>
        }
        </tbody>
    </table>
}

@code {
    private string token = string.Empty;
    private string pesquisa = string.Empty;
    private bool isLoading;
    private string? erro;
    private List<ProdutoViewModel> produtos = new();

    private async Task CarregarProdutos()
    {
        erro = null;
        produtos.Clear();

        if (string.IsNullOrWhiteSpace(token))
        {
            erro = "Informe o token da API Tiny.";
            return;
        }

        if (string.IsNullOrWhiteSpace(pesquisa))
        {
            erro = "Informe ao menos parte do nome ou código do produto para pesquisar.";
            return;
        }

        isLoading = true;

        try
        {
            var filtros = new Dictionary<string, string>
            {
                ["pesquisa"] = pesquisa
            };

            var retornoRoot = await TinyApi.ListarProdutosAsync(token, filtros);
            var ret = retornoRoot.Retorno;
            if (ret is null)
            {
                erro = "Resposta inválida da API Tiny (produtos).";
                return;
            }

            if (!string.Equals(ret.Status, "OK", StringComparison.OrdinalIgnoreCase))
            {
                erro = ret.Erros?.FirstOrDefault()?.Erro ?? ret.Status ?? "Erro na pesquisa de produtos.";
                return;
            }

            if (ret.Produtos is null || ret.Produtos.Count == 0)
            {
                erro = "Nenhum produto encontrado.";
                return;
            }

            foreach (var wrapper in ret.Produtos)
            {
                var prod = wrapper.Produto;
                if (prod is null)
                    continue;

                var vm = new ProdutoViewModel
                {
                    Id = prod.Id ?? string.Empty,
                    Nome = prod.Nome ?? string.Empty,
                    PrecoVenda = prod.Preco ?? 0m,
                    PrecoCusto = prod.PrecoCusto,

                    // A API de pesquisa de produtos não retorna frete e tributos diretamente.
                    ValorFrete = null,
                    Icms = null,
                    Pis = null,
                    Cofins = null,
                    Difal = null
                };

                produtos.Add(vm);
            }
        }
        catch (Exception ex)
        {
            erro = $"Erro ao carregar produtos: {ex.Message}";
        }
        finally
        {
            isLoading = false;
        }
    }

    private static string FormatCurrency(decimal? value)
        => value.HasValue ? value.Value.ToString("C2") : "-";

    private class ProdutoViewModel
    {
        public string Id { get; set; } = string.Empty;
        public string Nome { get; set; } = string.Empty;
        public decimal? PrecoCusto { get; set; }
        public decimal PrecoVenda { get; set; }
        public decimal? ValorFrete { get; set; }
        public decimal? Icms { get; set; }
        public decimal? Pis { get; set; }
        public decimal? Cofins { get; set; }
        public decimal? Difal { get; set; }
    }
}

